<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kitchen_bg">

    <LinearLayout
        android:id="@+id/splashContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/slp_blue"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="440dp"
            android:layout_height="440dp"
            android:contentDescription="@string/slp_logo" />

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/gotham"
            android:text="@string/meal_selection_kitchen"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/setupContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/kitchen_bg"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/setupFormContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/gotham"
                android:gravity="center"
                android:text="@string/setup_title"
                android:textColor="@color/kitchen_text_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/gotham"
                android:gravity="center"
                android:text="@string/setup_subtitle"
                android:textColor="@color/kitchen_text_secondary"
                android:textSize="16sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/kitchen_surface"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:strokeColor="#CCCCCC"
                app:strokeWidth="1dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/gotham"
                        android:text="@string/select_school_prompt"
                        android:textColor="@color/kitchen_text_primary"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/initialSchoolSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:background="@color/kitchen_bg"
                        android:fontFamily="@font/gotham"
                        android:paddingHorizontal="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/gotham"
                        android:text="@string/select_tablet_type"
                        android:textColor="@color/kitchen_text_primary"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/tabletTypeGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/kitchenTabletRadio"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@color/kitchen_bg"
                            android:fontFamily="@font/gotham"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/kitchen_side_tablet"
                            android:textColor="@color/kitchen_text_primary"
                            android:textSize="17sp" />

                        <RadioButton
                            android:id="@+id/childTabletRadio"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/kitchen_bg"
                            android:fontFamily="@font/gotham"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/child_facing_tablet"
                            android:textColor="@color/kitchen_text_primary"
                            android:textSize="17sp" />
                    </RadioGroup>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/gotham"
                        android:text="@string/username_label"
                        android:textColor="@color/kitchen_text_primary"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxBackgroundColor="@color/kitchen_bg"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="0dp"
                        app:boxCornerRadiusBottomStart="0dp"
                        app:boxCornerRadiusTopEnd="0dp"
                        app:boxCornerRadiusTopStart="0dp"
                        app:boxStrokeColor="@color/kitchen_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/usernameInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gotham"
                            android:hint="@string/username_hint"
                            android:paddingVertical="14dp"
                            android:singleLine="true"
                            android:textSize="18sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/gotham"
                        android:text="@string/password_label"
                        android:textColor="@color/kitchen_text_primary"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxBackgroundColor="@color/kitchen_bg"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="0dp"
                        app:boxCornerRadiusBottomStart="0dp"
                        app:boxCornerRadiusTopEnd="0dp"
                        app:boxCornerRadiusTopStart="0dp"
                        app:boxStrokeColor="@color/kitchen_text_secondary"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/passwordInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gotham"
                            android:hint="@string/password_hint"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:paddingVertical="14dp"
                            android:singleLine="true"
                            android:textSize="18sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/loginButton"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="@color/kitchen_success"
                        android:fontFamily="@font/gotham"
                        android:text="@string/continue_label"
                        android:textAllCaps="true"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:cornerRadius="6dp" />

                    <TextView
                        android:id="@+id/setupErrorText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="#FEF2F2"
                        android:fontFamily="@font/gotham"
                        android:gravity="center"
                        android:padding="10dp"
                        android:textColor="@color/kitchen_danger"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="120dp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/appContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="match_parent"
            android:layout_height="144dp"
            android:background="@color/kitchen_header_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/headerLogo"
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:contentDescription="@string/slp_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/headerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/gotham"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/headerSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/gotham"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/backToSetupButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="148dp"
                    android:layout_height="40dp"
                    android:backgroundTint="@color/button_secondary_bg"
                    android:fontFamily="@font/gotham"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="40dp"
                    android:text="@string/back_to_setup"
                    android:textAllCaps="true"
                    android:textColor="@color/button_secondary_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="6dp"
                    app:strokeColor="@color/button_secondary_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/changeSchoolButton"
                    android:layout_width="148dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/button_secondary_bg"
                    android:fontFamily="@font/gotham"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="40dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="12dp"
                    android:text="@string/change_school_with_icon"
                    android:textAllCaps="true"
                    android:textColor="@color/button_secondary_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="6dp"
                    app:strokeColor="@color/button_secondary_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/endServiceButton"
                    android:layout_width="148dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#FFFFFF"
                    android:fontFamily="@font/gotham"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="40dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="12dp"
                    android:text="@string/end_service_with_icon"
                    android:textAllCaps="true"
                    android:textColor="#B71C1C"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="6dp"
                    app:icon="@android:drawable/presence_busy"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="#D32F2F"
                    app:strokeColor="#E0B4B4"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/appScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="16dp"
            android:paddingBottom="56dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/contentTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="@font/gotham_ultra"
                    android:textAllCaps="true"
                    android:textColor="@color/kitchen_text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/contentSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/gotham"
                    android:textSize="18sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/kitchenContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/prepAndLoadRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/prepListContainer"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            app:cardBackgroundColor="@color/kitchen_surface"
                            app:cardCornerRadius="0dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#CCCCCC"
                            app:strokeWidth="1dp"
                            app:cardUseCompatPadding="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="18dp">

                                <TextView
                                    android:id="@+id/prepListTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/gotham_ultra"
                                    android:textAllCaps="true"
                                    android:text="@string/meals_to_prepare_with_icon"
                                    android:textColor="@color/meal_name_text"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:id="@+id/prepSummaryContainer"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:orientation="vertical" />

                                <TextView
                                    android:id="@+id/prepLoadingText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:fontFamily="@font/gotham"
                                    android:text="@string/loading_todays_meals"
                                    android:textColor="@color/kitchen_warning"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:visibility="gone" />

                                <ProgressBar
                                    android:id="@+id/prepLoadingProgress"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="16dp"
                                    android:layout_marginTop="10dp"
                                    android:indeterminate="true"
                                    android:indeterminateTint="@color/kitchen_success"
                                    android:progressTint="@color/kitchen_success"
                                    android:progressBackgroundTint="@color/button_secondary_border"
                                    android:visibility="gone" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Pause/Resume service sits directly below the meals box -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/pauseServiceButton"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/button_secondary_bg"
                        android:fontFamily="@font/gotham"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/pause_service_button_with_icon"
                        android:textAllCaps="true"
                        android:textColor="@color/button_secondary_text"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:cornerRadius="6dp"
                        app:strokeColor="@color/button_secondary_border"
                        app:strokeWidth="1dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/serviceStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/gotham"
                        android:gravity="start"
                        android:textColor="@color/kitchen_text_secondary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/kitchenPrimaryActionsRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/loadTodaysMealsButton"
                            android:layout_width="160dp"
                            android:layout_height="160dp"
                            android:backgroundTint="@color/kitchen_success"
                            android:fontFamily="@font/gotham"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="8dp"
                            android:text="@string/load_todays_meals"
                            android:textAllCaps="true"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:cornerRadius="6dp"
                            app:icon="@android:drawable/stat_sys_upload"
                            app:iconGravity="textTop"
                            app:iconPadding="6dp"
                            app:iconSize="30dp"
                            app:iconTint="@color/white" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/startServiceButton"
                            android:layout_width="160dp"
                            android:layout_height="160dp"
                            android:layout_marginStart="36dp"
                            android:backgroundTint="@color/kitchen_success"
                            android:fontFamily="@font/gotham"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="@string/start_service_button_with_icon"
                            android:textAllCaps="true"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            app:cornerRadius="6dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/serviceControlContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@color/kitchen_bg"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/firebaseStatusText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="#FEF2F2"
                            android:fontFamily="@font/gotham"
                            android:padding="10dp"
                            android:textColor="@color/kitchen_danger"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/kitchenOrderContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/kitchenOrderChildName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gotham"
                            android:gravity="center"
                            android:textSize="40sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/kitchenOrderMealName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:fontFamily="@font/gotham"
                            android:gravity="center"
                            android:textSize="34sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/kitchenOrderDietaryRequirements"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/gotham"
                            android:gravity="center"
                            android:textColor="@color/kitchen_danger"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/mealServedButton"
                            android:layout_width="match_parent"
                            android:layout_height="96dp"
                            android:layout_marginTop="20dp"
                            android:backgroundTint="@color/kitchen_success"
                            android:fontFamily="@font/gotham"
                            android:textAllCaps="true"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            app:cornerRadius="6dp"
                            android:text="@string/meal_served" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/childContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/childServiceGateText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/gotham"
                        android:textColor="@color/child_green"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/startMealTimeButton"
                        android:layout_width="match_parent"
                        android:layout_height="96dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/kitchen_success"
                        android:fontFamily="@font/gotham"
                        android:text="@string/start_meal_time"
                        android:textAllCaps="true"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:cornerRadius="6dp" />

                    <FrameLayout
                        android:id="@+id/childStepContainer"
                        android:layout_width="match_parent"
                        android:layout_height="520dp"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <ScrollView
                            android:id="@+id/classSelectionContainer"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fillViewport="true"
                            android:fadeScrollbars="false"
                            android:scrollbarAlwaysDrawVerticalTrack="true"
                            android:scrollbarStyle="outsideOverlay"
                            android:scrollbars="vertical"
                            android:visibility="gone">

                            <LinearLayout
                                android:id="@+id/classButtonsContainer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />
                        </ScrollView>

                        <LinearLayout
                            android:id="@+id/nameSelectionContainer"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/backToClassesButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:backgroundTint="@color/button_secondary_bg"
                                android:fontFamily="@font/gotham"
                                android:text="@string/back_to_classes"
                                android:textAllCaps="true"
                                android:textColor="@color/button_secondary_text"
                                android:textStyle="bold"
                                app:cornerRadius="6dp"
                                app:strokeColor="@color/button_secondary_border"
                                app:strokeWidth="1dp" />

                            <ScrollView
                                android:id="@+id/nameListScroll"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_marginTop="8dp"
                                android:layout_weight="1"
                                android:fillViewport="true"
                                android:fadeScrollbars="false"
                                android:scrollbarAlwaysDrawVerticalTrack="true"
                                android:scrollbarStyle="outsideOverlay"
                                android:scrollbars="vertical">

                                <LinearLayout
                                    android:id="@+id/nameButtonsContainer"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical" />
                            </ScrollView>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/checkInSuccessContainer"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/checkInSuccessButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0.85"
                                android:backgroundTint="@color/child_green"
                                android:fontFamily="@font/gotham"
                                android:text="@string/check_in_success_large"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textSize="40sp"
                                android:textStyle="bold"
                                app:cornerRadius="6dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/oopsButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginStart="8dp"
                                android:layout_weight="0.15"
                                android:backgroundTint="#D32F2F"
                                android:fontFamily="@font/gotham"
                                android:text="@string/oops"
                                android:textAllCaps="true"
                                android:textColor="@color/white"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                app:cornerRadius="6dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/waitingOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#CC000000"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/gotham"
                                android:text="@string/waiting_for_kitchen_overlay"
                                android:textColor="@color/white"
                                android:textSize="36sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="#323232"
            android:gravity="center_vertical|end"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/gotham"
                android:text="@string/powered_by"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/footerLogo"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/tech_and_that_logo" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
