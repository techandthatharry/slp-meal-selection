<?xml version="1.0" encoding="utf-8"?>
<!-- Gotham font family — Book weight for body text, Black for emphasis. -->
<font-family xmlns:app="http://schemas.android.com/apk/res-auto">
    <font
        app:font="@font/gotham_light"
        app:fontStyle="normal"
        app:fontWeight="300" />
    <font
        app:font="@font/gotham_book"
        app:fontStyle="normal"
        app:fontWeight="400" />
    <font
        app:font="@font/gotham_black"
        app:fontStyle="normal"
        app:fontWeight="700" />
</font-family>
